# ============================================================
#  Конфигурация локального мультиагентного ассистента
#  Скопируйте этот файл в backend/.env и заполните значения.
# ============================================================

# Провайдер LLM: anthropic | openai | none | auto
# auto = выбрать anthropic, если задан ANTHROPIC_API_KEY, иначе openai, иначе none.
# none = деградационный rule-based режим (работает без ключа, для демо).
LLM_PROVIDER=auto

# --- Anthropic ---
ANTHROPIC_API_KEY=
# Уточните доступную вам модель (например claude-sonnet-4-6, claude-opus-4-6).
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- OpenAI (альтернатива) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=  # для совместимых API (например локальный прокси)

# --- Поведение агентов ---
LLM_MAX_TOKENS=1500
LLM_TEMPERATURE=0.2
MAX_AGENT_STEPS=8

# --- Прочее ---
TIMEZONE=Europe/Moscow
CORS_ORIGINS=*
