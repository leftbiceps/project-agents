# ============================================================================
#  Конфигурация локального мультиагентного ассистента (Docker Compose)
#  Скопируйте в .env:  cp .env.example .env
# ============================================================================

# --- Провайдер LLM ---
# local_openai = локальный OpenAI-совместимый сервер (llama.cpp / Qwen) — режим по умолчанию для Docker.
# Другие значения: anthropic | openai | none | auto
LLM_PROVIDER=local_openai

# Адрес локального LLM внутри compose-сети (backend -> llm)
LLM_BASE_URL=http://llm:8000/v1
LLM_API_KEY=local
LLM_MODEL=qwen-3.5-9b-int6

# --- Параметры локального inference (llama.cpp server) ---
# Путь к модели ВНУТРИ llm-контейнера (хостовая папка ./models смонтирована в /models).
# int6-квантизация в llama.cpp обычно называется Q6_K — см. docs/LLM_LOCAL_INFERENCE.md.
LLM_MODEL_PATH=/models/qwen-3.5-9b-int6.gguf
LLM_CONTEXT_SIZE=8192
LLM_THREADS=8
# CPU режим: 0. GPU режим (make up-gpu): например 999 (все слои на GPU).
LLM_GPU_LAYERS=0

# Образы llama.cpp (переопределяйте при необходимости)
LLM_IMAGE=ghcr.io/ggml-org/llama.cpp:server
LLM_IMAGE_GPU=ghcr.io/ggml-org/llama.cpp:server-cuda

# --- Поведение агентов ---
LLM_MAX_TOKENS=1500
LLM_TEMPERATURE=0.2
MAX_AGENT_STEPS=8

# --- Порты на хосте ---
FRONTEND_PORT=3000
BACKEND_PORT=8000
LLM_PORT=8001

# --- Прочее ---
TIMEZONE=Europe/Moscow
CORS_ORIGINS=*

# ----------------------------------------------------------------------------
# Облачные провайдеры (НЕ требуются для локального режима; оставьте пустыми):
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
# ----------------------------------------------------------------------------
